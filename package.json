{
  "name": "credflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:local": "hardhat run scripts/deploy.js",
    "deploy:robinhood": "hardhat run scripts/deploy.js --network robinhoodTestnet",
    "deploy:oapp": "hardhat run scripts/deploy-oapp.js --network robinhoodTestnet",
    "lz:status": "node scripts/lz-status.js",
    "lz:set-peers": "hardhat run scripts/set-peers.js --network robinhoodTestnet",
    "oracle:wire": "hardhat run scripts/wire-oracle.js --network robinhoodTestnet",
    "smoke:borrow": "hardhat run scripts/smoke-borrow.js --network robinhoodTestnet",
    "test:blacklist": "hardhat run scripts/test-blacklist.js --network robinhoodTestnet",
    "unblacklist:wallet": "hardhat run scripts/unblacklist-wallet.js --network robinhoodTestnet",
    "base-sepolia:check": "set BASE_SEPOLIA_CHECK_ONLY=1&& hardhat run scripts/base-sepolia-activity.js --network baseSepolia",
    "base-sepolia:activity": "hardhat run scripts/base-sepolia-activity.js --network baseSepolia",
    "base-sepolia:aave:check": "set BASE_SEPOLIA_AAVE_CHECK_ONLY=1&& hardhat run scripts/base-sepolia-aave.js --network baseSepolia",
    "base-sepolia:aave": "hardhat run scripts/base-sepolia-aave.js --network baseSepolia",
    "arbitrum-sepolia:aave:check": "set ARBITRUM_SEPOLIA_AAVE_CHECK_ONLY=1&& hardhat run scripts/arbitrum-sepolia-aave.js --network arbitrumSepolia",
    "arbitrum-sepolia:aave": "hardhat run scripts/arbitrum-sepolia-aave.js --network arbitrumSepolia",
    "ml:train": "credflow-env\\Scripts\\python.exe scripts/train_ml.py",
    "ml:sybil-train": "credflow-env\\Scripts\\python.exe scripts/train_sybil.py",
    "ml:serve": "credflow-env\\Scripts\\python.exe -m ml.scoring_api",
    "ml:test": "credflow-env\\Scripts\\python.exe -m pytest tests/ -v",
    "test:sybil": "credflow-env\\Scripts\\python.exe scripts/test_sybil_rgcn.py",
    "test:graph": "credflow-env\\Scripts\\python.exe scripts/test_graph_analysis.py",
    "fund:lending": "hardhat run scripts/fund-lending.js --network robinhoodTestnet"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.12",
    "chai": "^4.5.0",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.5",
    "hardhat": "^2.22.18"
  },
  "dependencies": {
    "@chainlink/contracts": "^1.3.0",
    "@layerzerolabs/lz-evm-messagelib-v2": "^2.3.44",
    "@layerzerolabs/lz-evm-oapp-v2": "^2.3.44",
    "@layerzerolabs/lz-evm-protocol-v2": "^2.3.44",
    "@openzeppelin/contracts": "^4.9.6",
    "@openzeppelin/contracts-upgradeable": "^4.9.6"
  }
}
